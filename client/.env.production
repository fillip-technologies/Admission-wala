# Used automatically by `vite build` (production). The built static site has no
# dev proxy, so it must call the backend by its absolute URL.
# Cross-site is fine now — auth uses an Authorization: Bearer token, not cookies.
VITE_API_URL=https://api.shreeadmissiongurukul.com/api/v1

# WhatsApp floating button — international format, no "+", "0" or spaces.
# Kept here (not just in .env) so production builds are self-contained.
VITE_WHATSAPP_NUMBER=918409835444
