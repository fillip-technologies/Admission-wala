# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables (set these in the Render dashboard → Environment)
# Copy to a local `.env` for development. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=production
# PORT is provided by Render automatically — do NOT hardcode it in production.
PORT=3000

# Extra allowed CORS origins (comma-separated). The production frontend and
# localhost are always allowed; add anything else here.
CLIENT_URL=https://shreeadmissiongurukul.fillipsoftware.com

# Database (MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# Auth / JWT
ACCESS_TOKEN_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change-me-to-another-long-random-string
REFRESH_TOKEN_EXPIRES_IN=30d
# Optional — password hashing rounds (default 12)
SALT=12

# Email / OTP
# ── Production (Render): use Resend's HTTPS API. Render blocks outbound SMTP,
#    so SMTP times out there. If RESEND_API_KEY is set, email is sent via Resend
#    and SMTP is ignored.
RESEND_API_KEY=re_NyTbTot6_7Cevi2bWF8enUdENF67Djk2H
# Verified sender in Resend. For a quick test you may use onboarding@resend.dev;
# for production verify your domain and use e.g. no-reply@shreeadmissiongurukul.fillipsoftware.com
RESEND_FROM=no-reply@shreeadmissiongurukul.fillipsoftware.com

# ── Local dev fallback (used only when RESEND_API_KEY is NOT set).
#    Gmail SMTP shown; use an App Password, not your login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com

# Optional — OTP validity in minutes (default 10)
OTP_EXP_MINUTES=10

# Cloudinary (admission document uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
